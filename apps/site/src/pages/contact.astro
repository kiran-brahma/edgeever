---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Contact"
  description="Contact Kiran Brahma Notes."
>
  <Container>
    <main class="mx-auto max-w-3xl py-12 md:py-20 text-slate-700">
      <section class="rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
        <h1 class="text-2xl font-bold text-gray-900">Contact</h1>
        <p class="mt-3 text-base leading-7 text-slate-500">
          For support or inquiries, reach out via the deployed instance or email Kiran Brahma directly.
        </p>
      </section>
    </main>
  </Container>
</Layout>
