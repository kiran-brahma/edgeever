---
import Container from "@/components/container.astro";
import { Icon } from "astro-icon/components";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const appUrl = "https://notes.kiranbrahma.com";
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a
          href="/"
          class="flex items-center gap-2 text-lg"
          aria-label="Kiran Brahma Notes home"
        >
          <span
            class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--edgeever-brand-logo-bg)]"
          >
            <svg
              class="h-6 w-6"
              viewBox="0 0 64 64"
              role="img"
              aria-hidden="true"
            >
              <rect
                x="14"
                y="10"
                width="36"
                height="44"
                rx="8"
                fill="var(--edgeever-brand-logo-mark)"
              ></rect>
              <path
                d="M24 23h18v5H30v5h11v5H30v6h13v5H24V23Z"
                fill="var(--edgeever-brand-surface)"></path>
              <path
                d="M19 16h26"
                stroke="var(--edgeever-brand-logo-accent)"
                stroke-width="3"
                stroke-linecap="round"></path>
            </svg>
          </span>
          <span>
            <span class="font-bold text-slate-800">Kiran</span><span
              class="text-slate-500">Brahma</span>
          </span>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          <li>
            <a
              href={appUrl}
              class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-gray-900"
            >
              <span>Login</span>
            </a>
          </li>
        </ul>
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <a
            href={appUrl}
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-slate-200 bg-white text-gray-600 transition hover:border-slate-300 hover:text-gray-900"
            aria-label="Login"
          >
            <Icon class="h-5 w-5" name="bx:bx-log-in" />
          </a>
        </div>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={appUrl}
          class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-gray-600 transition hover:border-slate-300 hover:text-gray-900"
        >
          Login
        </a>
      </div>
    </div>
  </header>
</Container>
