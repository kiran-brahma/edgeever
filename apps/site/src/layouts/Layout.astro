---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import { siteCopy } from "@/i18n";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  openGraphType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  localeRedirect?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const copy = siteCopy["en-US"].layout;
const defaultDescription = copy.defaultDescription;

const {
  title,
  description = defaultDescription,
  image = "/opengraph.jpg",
  imageAlt = copy.imageAlt,
  openGraphType = "website",
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags,
  jsonLd,
  noindex = false,
} = Astro.props;

const resolvedImageWithDomain = new URL(image, Astro.site).toString();

const makeTitle = title ? title + " | " + "Kiran Brahma Notes" : copy.defaultTitle;

const faviconVersion = "edgeever-brand-20260703";
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href={`/favicon.ico?v=${faviconVersion}`} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`/icon-192.png?v=${faviconVersion}`} />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${faviconVersion}`} />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      twitter={{
        creator: "@kiranbrahma",
        site: "@kiranbrahma",
        card: "summary_large_image",
        title: makeTitle,
        description,
        image: resolvedImageWithDomain,
        imageAlt,
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: openGraphType,
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        optional: {
          description,
          locale: copy.ogLocale,
          siteName: "Kiran Brahma Notes",
        },
        image: {
          alt: imageAlt,
        },
        article:
          openGraphType === "article"
            ? {
                publishedTime: articlePublishedTime,
                modifiedTime: articleModifiedTime,
                authors: articleAuthor ? [articleAuthor] : undefined,
                section: articleSection,
                tags: articleTags,
              }
            : undefined,
      }}
    />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
